# 1) Создайте бота в @BotFather и вставьте токен сюда
BOT_TOKEN=1234567890:PASTE_YOUR_BOT_TOKEN_HERE

# 2) Ваш Telegram ID. Узнать можно в @userinfobot
ADMIN_ID=123456789

# 3) Username поддержки без @
SUPPORT_USERNAME=your_support_username

# 4) Username вашего бота без @. Можно оставить пустым, бот сам попробует определить.
BOT_USERNAME=

# 5) Валюта, которая будет показываться в меню: ₽, ₸, $, TON и т.д.
CURRENCY_SYMBOL=₽

# 6) Реквизиты/инструкция для ручной оплаты, которую увидит клиент при заявке
PAYMENT_DETAILS=Kaspi/Card/СБП: укажите ваши реквизиты и комментарий к оплате

# 7) Процент бонуса партнёру за выполненный заказ приглашённого клиента
REFERRAL_BONUS_PERCENT=5

# 8) Путь к базе. Обычно менять не нужно.
BOT_DB_PATH=data/bot.db
