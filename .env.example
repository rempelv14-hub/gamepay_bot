BOT_TOKEN=your_bot_token_from_BotFather

# Можно оставить ADMIN_ID для одного админа
ADMIN_ID=123456789

# Или указать несколько админов через запятую
ADMIN_IDS=123456789,987654321

# Роли админов:
# OWNER_IDS — владелец: всё может
# MANAGER_IDS — менеджер: заказы, тикеты, статистика
# SUPPORT_IDS — поддержка: только тикеты и ответы клиентам
# Если OWNER_IDS не указан, ADMIN_ID/ADMIN_IDS становятся владельцами.
OWNER_IDS=
MANAGER_IDS=
SUPPORT_IDS=

SUPPORT_USERNAME=your_username_without_at
BOT_USERNAME=gamepay_shop_bot
CURRENCY_SYMBOL=₸
REFERRAL_BONUS_PERCENT=5
PAYMENT_DETAILS=Kaspi Gold / карта / инструкция оплаты
BOT_DB_PATH=data/bot.db

# TON автооплата
TON_WALLET=UQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TON_API_KEY=your_toncenter_api_key
TON_RATE_KZT=1200
# 1 = брать актуальный курс TON/KZT автоматически, 0 = использовать TON_RATE_KZT вручную
TON_RATE_AUTO_ENABLED=0
TON_RATE_CACHE_MINUTES=15
TON_CHECK_LIMIT=50
TON_INVOICE_TTL_MINUTES=30

# Безопасный возврат TON-оплаты на внутренний баланс при отмене заказа
REFUND_TO_BALANCE_ENABLED=1

# Автобэкап базы. 1 = включить, 0 = выключить
AUTO_BACKUP_ENABLED=0
AUTO_BACKUP_HOUR=9
